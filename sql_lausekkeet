"Projektissa on yksi uusi table luotu nimeltä perks"

CREATE TABLE `perks` (
	`name` VARCHAR(20) NULL DEFAULT NULL COLLATE 'latin1_swedish_ci',
	`score` INT(11) NULL DEFAULT NULL,
	`mult` INT(11) NULL DEFAULT NULL,
	`xmult` INT(11) NULL DEFAULT NULL
)

"Kaikki data on laitettu insertillä"
"Esim INSERT INTO perks (name, score, mult, xmult) VALUES ('jackpot1','10','5','2');"
